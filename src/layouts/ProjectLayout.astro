---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  category: string;
  period: string;
  githubUrl?: string;
  liveUrl?: string;
  videoUrl?: string;
  techTags: string[];
}

const {
  title,
  description,
  category,
  period,
  githubUrl = "https://github.com/srikar2908",
  liveUrl,
  videoUrl,
  techTags,
} = Astro.props;
---

<BaseLayout title={`${title} — Project Case Study | Srikar Kukkadapu`} description={description}>
  <article class="min-h-screen pt-24 pb-16 md:pt-32 md:pb-24">
    <!-- Hero Banner Area -->
    <div class="relative overflow-hidden border-b border-border bg-surface-light dark:bg-surface-dark py-12 md:py-20 mb-12">
      <!-- Background subtle light glow -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-accent/5 rounded-full blur-[120px] pointer-events-none"></div>
      
      <div class="max-w-6xl mx-auto px-4 md:px-8 relative z-10">
        <!-- Breadcrumb link -->
        <a 
          href="/#projects" 
          class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-accent transition-colors mb-6 group"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:-translate-x-1"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
          Back to Projects
        </a>

        <!-- Main Meta Details -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
          <div class="lg:col-span-2">
            <span class="inline-block px-3 py-1 text-xs font-semibold text-accent bg-accent/10 rounded-full mb-4">
              {category}
            </span>
            <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight mb-4">
              {title}
            </h1>
            <p class="text-lg text-muted-foreground leading-relaxed max-w-2xl">
              {description}
            </p>
          </div>

          <!-- Sticky-style quick info card -->
          <div class="glass-card p-6 lg:p-8 flex flex-col gap-6 w-full lg:sticky lg:top-24">
            <div>
              <span class="text-xs font-semibold uppercase text-muted-foreground block mb-1">Timeline</span>
              <span class="text-sm font-medium">{period}</span>
            </div>
            
            <div>
              <span class="text-xs font-semibold uppercase text-muted-foreground block mb-2">Technologies Used</span>
              <div class="flex flex-wrap gap-1.5">
                {techTags.map((tag) => (
                  <span class="px-2.5 py-1 text-xs font-medium bg-secondary text-secondary-foreground rounded-md border border-border">
                    {tag}
                  </span>
                ))}
              </div>
            </div>

            <!-- External Action Links -->
            <div class="flex flex-col gap-2.5 pt-2">
              {liveUrl && (
                <a 
                  href={liveUrl} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="flex items-center justify-center gap-2 px-4 py-2.5 text-sm font-semibold text-accent-foreground bg-accent hover:bg-accent-hover rounded-xl shadow-sm transition-colors text-center w-full"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                  Visit Live Demo
                </a>
              )}
              {videoUrl && (
                <a 
                  href={videoUrl} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="flex items-center justify-center gap-2 px-4 py-2.5 text-sm font-semibold border border-border hover:bg-secondary rounded-xl transition-colors text-center w-full"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"></polygon><rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect></svg>
                  Watch Video Demo
                </a>
              )}
              {githubUrl && (
                <a 
                  href={githubUrl} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="flex items-center justify-center gap-2 px-4 py-2.5 text-sm font-semibold border border-border hover:bg-secondary rounded-xl transition-colors text-center w-full"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
                  View GitHub Source
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Case Study Body Content -->
    <div class="max-w-6xl mx-auto px-4 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Main Details (Left Col) -->
        <div class="lg:col-span-2 space-y-12 prose dark:prose-invert max-w-none">
          <slot />
        </div>
        
        <!-- Empty or extra widgets sidebar (Right Col - hidden on mobile / desktop auxiliary details) -->
        <div class="hidden lg:block space-y-6">
          <div class="glass-card p-6">
            <h4 class="text-sm font-semibold uppercase text-muted-foreground mb-4">Contact Srikar</h4>
            <p class="text-sm text-muted-foreground mb-4">
              Interested in this project or have a collaboration in mind? Let's connect.
            </p>
            <a 
              href="/#contact" 
              class="inline-flex items-center gap-1 text-sm font-semibold text-accent hover:underline"
            >
              Get in Touch 
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Case Study Nav -->
    <div class="border-t border-border mt-16 md:mt-24 pt-12">
      <div class="max-w-6xl mx-auto px-4 md:px-8 flex items-center justify-between">
        <a 
          href="/#projects" 
          class="inline-flex items-center gap-2 text-sm font-semibold text-muted-foreground hover:text-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
          All Projects
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
