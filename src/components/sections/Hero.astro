---
import Typewriter from '../ui/Typewriter.tsx';
import { personalInfo } from '../../data/personal.ts';
---

<section class="relative min-h-screen flex flex-col justify-center items-center overflow-hidden px-4 py-20 text-center">
  <!-- Soft accent background glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-7xl h-[600px] bg-gradient-to-b from-accent/5 to-transparent rounded-full blur-[120px] pointer-events-none"></div>

  <div class="max-w-4xl mx-auto flex flex-col items-center z-10">
    <!-- Pulse Badge -->
    <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full border border-success/20 bg-success/5 text-success text-xs font-semibold mb-6 shadow-sm">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-success"></span>
      </span>
      Available for Opportunities
    </div>

    <!-- Title -->
    <h1 class="text-4xl sm:text-6xl md:text-7xl font-extrabold tracking-tight mb-2 text-primary">
      {personalInfo.name}
    </h1>

    <!-- Rotating roles typewriter -->
    <div class="text-xl sm:text-2xl md:text-3xl font-semibold mb-6 text-muted-foreground h-[40px] flex items-center justify-center">
      <span class="mr-2">I am a</span>
      <Typewriter 
        client:load 
        words={["Python Developer", "AI Engineer", "Backend Developer", "Full Stack Developer"]} 
      />
    </div>

    <!-- Tagline -->
    <p class="text-base sm:text-lg md:text-xl text-muted-foreground max-w-xl sm:max-w-2xl leading-relaxed mb-10">
      {personalInfo.tagline}
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 w-full sm:w-auto mb-12">
      <a 
        href="#projects" 
        class="flex items-center justify-center gap-1.5 px-6 py-3 w-full sm:w-auto text-sm font-semibold text-accent-foreground bg-accent hover:bg-accent-hover rounded-xl shadow-sm hover:shadow transition-all duration-200"
      >
        View Projects
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </a>
      
      <a 
        href={personalInfo.resumeUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center gap-1.5 px-6 py-3 w-full sm:w-auto text-sm font-semibold border border-border hover:bg-secondary/50 rounded-xl transition-all duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
        Download Resume
      </a>

      <a 
        href="#contact"
        class="flex items-center justify-center gap-1 text-sm font-semibold text-muted-foreground hover:text-accent transition-colors py-2"
      >
        Contact Me
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="translate-y-[0.5px]"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </a>
    </div>

    <!-- Social Links Row -->
    <div class="flex items-center gap-6 text-muted-foreground">
      <a 
        href={personalInfo.githubUrl} 
        target="_blank" 
        rel="noopener noreferrer" 
        class="hover:text-accent transition-colors duration-200"
        aria-label="GitHub Profile"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
      </a>
      <a 
        href={personalInfo.linkedinUrl} 
        target="_blank" 
        rel="noopener noreferrer" 
        class="hover:text-accent transition-colors duration-200"
        aria-label="LinkedIn Profile"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
      </a>
      <a 
        href={`mailto:${personalInfo.email}`} 
        class="hover:text-accent transition-colors duration-200"
        aria-label="Send Email"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"></path><path d="M22 2 11 13"></path></svg>
      </a>
    </div>
  </div>

  <!-- Scroll Down chevron -->
  <a 
    href="#about" 
    class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 text-xs text-muted-foreground hover:text-accent transition-colors group cursor-pointer"
    aria-label="Scroll to About Section"
  >
    <span>Explore</span>
    <svg 
      xmlns="http://www.w3.org/2000/svg" 
      width="18" 
      height="18" 
      viewBox="0 0 24 24" 
      fill="none" 
      stroke="currentColor" 
      stroke-width="2" 
      stroke-linecap="round" 
      stroke-linejoin="round"
      class="animate-bounce"
    >
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </a>
</section>
