---
import { educationList } from '../../data/education.ts';
---

<section id="education" class="py-20 lg:py-28 border-t border-border bg-surface-light dark:bg-surface-dark transition-colors duration-300">
  <div class="max-w-4xl mx-auto px-4 md:px-8">
    <div class="mb-16 text-center">
      <span class="text-xs font-bold uppercase tracking-widest text-accent mb-2 block">Education</span>
      <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight mb-3 text-primary">
        Academic Background
      </h2>
      <p class="text-muted-foreground max-w-md mx-auto text-sm sm:text-base">
        My formal education, specialized coursework, and academic credentials.
      </p>
    </div>

    <!-- Timeline Layout -->
    <div class="relative border-l border-border/80 ml-4 md:ml-6 pl-6 md:pl-10 space-y-12">
      {educationList.map((edu, idx) => (
        <div class="relative group">
          
          <!-- Timeline Indicator Node -->
          <div class={`absolute -left-[31px] md:-left-[47px] top-1.5 w-4 h-4 rounded-full border-2 border-background bg-accent ${idx === 0 ? 'ring-4 ring-accent/15 animate-pulse-subtle' : ''}`}></div>

          <!-- Content Card -->
          <div class="glass-card p-6 md:p-8 flex flex-col md:flex-row md:items-start justify-between gap-6 hover:border-accent/30 transition-all duration-300">
            <div class="space-y-4 max-w-xl">
              <div>
                <!-- Duration -->
                <span class="text-xs font-semibold text-accent uppercase tracking-wider block mb-1">
                  {edu.duration}
                </span>
                
                <!-- Institution & Location -->
                <h3 class="text-xl font-bold text-primary group-hover:text-accent transition-colors leading-snug">
                  {edu.institution}
                </h3>
                <span class="text-xs font-medium text-muted-foreground block mt-0.5">
                  📍 {edu.location}
                </span>
              </div>

              <!-- Degree / Stream -->
              <div class="text-sm font-semibold text-primary/95">
                {edu.degree}
              </div>

              <!-- Highlights list -->
              <ul class="space-y-2 list-none p-0 m-0">
                {edu.highlights.map((highlight) => (
                  <li class="text-xs text-muted-foreground flex items-start gap-2">
                    <span class="text-accent text-[10px] mt-0.5" aria-hidden="true">◆</span>
                    <span>{highlight}</span>
                  </li>
                ))}
              </ul>
            </div>

            <!-- Score badge -->
            <div class="md:text-right shrink-0">
              <span class="inline-block px-3 py-1.5 text-xs font-bold text-accent bg-accent/10 border border-accent/25 rounded-md text-center">
                {edu.score}
              </span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes pulse-subtle {
    0%, 100% {
      transform: scale(1);
      box-shadow: 0 0 0 0 rgba(37, 99, 235, 0.4);
    }
    50% {
      transform: scale(1.1);
      box-shadow: 0 0 0 6px rgba(37, 99, 235, 0.1);
    }
  }
  .animate-pulse-subtle {
    animation: pulse-subtle 2s infinite ease-in-out;
  }
</style>
