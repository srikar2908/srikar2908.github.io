---
const projects = [
  {
    title: "AI Database Copilot",
    tag: "AI · Backend · Full Stack",
    description: "A multi-tenant natural language to SQL platform that converts plain English queries into optimized, secure SQL across enterprise database schemas using a deterministic 11-stage LangGraph pipeline.",
    tech: ["Python", "FastAPI", "LangGraph", "Supabase", "React", "Docker", "JWT"],
    github: "https://github.com/srikar2908",
    live: "https://ai-db-copilot-frontend.onrender.com",
    caseStudy: "/projects/ai-db-copilot"
  },
  {
    title: "Gridlock Sentinel",
    tag: "ML · Traffic Intelligence",
    description: "An AI traffic monitoring platform featuring a predictive road-closure engine (87.1% accuracy, 0.773 AUC-ROC), semantic retrieval via FAISS, and real-time LLM-generated operational summaries.",
    tech: ["FastAPI", "XGBoost", "FAISS", "MongoDB", "Sentence Transformers", "Groq LLM"],
    github: "https://github.com/srikar2908",
    live: "https://huggingface.co/spaces/SandeepChakka/gridlock-sentinel",
    caseStudy: "/projects/gridlock-sentinel"
  },
  {
    title: "CampusTrack",
    tag: "Mobile · Firebase · Award-Winning",
    description: "Award-winning cross-platform lost-and-found mobile app built with Flutter and Firebase, reducing reporting latency from 120s to under 10s with a 92% asset recovery success rate.",
    tech: ["Flutter", "Dart", "Firebase", "Cloud Functions", "FCM", "Firestore"],
    github: "https://github.com/srikar2908",
    caseStudy: "/projects/campustrack"
  },
  {
    title: "Blogs FastAPI",
    tag: "Backend · API",
    description: "A production-grade blogging REST API backend built with FastAPI, featuring full CRUD, authentication, and a clean modular architecture deployed on Render.",
    tech: ["Python", "FastAPI", "PostgreSQL", "SQLAlchemy", "JWT"],
    github: "https://github.com/srikar2908",
    live: "https://blogs-fastapi.onrender.com",
    caseStudy: "/projects/blogs-fastapi"
  }
];
---

<section id="projects" class="py-20 lg:py-28 border-t border-border bg-surface-light dark:bg-surface-dark transition-colors duration-300">
  <div class="max-w-6xl mx-auto px-4 md:px-8">
    <div class="mb-16 text-center">
      <span class="text-xs font-bold uppercase tracking-widest text-accent mb-2 block">Featured Projects</span>
      <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight mb-3 text-primary">
        Production systems built end-to-end.
      </h2>
      <p class="text-muted-foreground max-w-xl mx-auto text-sm sm:text-base">
        Click on any project to explore the deep-dive technical case study and system architecture.
      </p>
    </div>

    <!-- 2x2 Projects Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {projects.map((project) => (
        <div class="glass-card p-6 sm:p-8 flex flex-col justify-between items-start h-full group hover:border-accent/30 transition-all duration-300">
          <div class="w-full">
            <!-- Category Tag -->
            <span class="text-[10px] font-bold tracking-widest uppercase text-accent mb-3 block">
              {project.tag}
            </span>
            
            <!-- Title -->
            <h3 class="text-xl sm:text-2xl font-bold tracking-tight mb-3 text-primary group-hover:text-accent transition-colors">
              {project.title}
            </h3>
            
            <!-- Description -->
            <p class="text-sm text-muted-foreground leading-relaxed mb-6">
              {project.description}
            </p>
            
            <!-- Tech badges -->
            <div class="flex flex-wrap gap-1.5 mb-8">
              {project.tech.map((t) => (
                <span class="px-2 py-0.5 text-xs bg-secondary text-secondary-foreground border border-border rounded-md">
                  {t}
                </span>
              ))}
            </div>
          </div>

          <!-- Project Actions footer -->
          <div class="flex items-center justify-between w-full border-t border-border/50 pt-4 mt-auto">
            <a 
              href={project.caseStudy} 
              class="inline-flex items-center gap-1 text-sm font-semibold text-accent hover:underline group/link"
            >
              View Case Study
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover/link:translate-x-0.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </a>

            <div class="flex items-center gap-3 text-muted-foreground">
              {project.github && (
                <a 
                  href={project.github} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="hover:text-accent transition-colors"
                  aria-label={`View ${project.title} on GitHub`}
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
                </a>
              )}
              {project.live && (
                <a 
                  href={project.live} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="hover:text-accent transition-colors"
                  aria-label={`Visit ${project.title} live demo`}
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
